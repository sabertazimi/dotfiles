# Enable the subsequent settings only in interactive sessions
case $- in
  *i*) ;;
    *) return;;
esac

# Environment
export EDITOR="nvim"
export VISUAL="nvim"
export PATH="$HOME/.local/bin:$HOME/go/bin:$PATH"
export RIPGREP_CONFIG_PATH="$HOME/.ripgreprc"
export FZF_DEFAULT_COMMAND="fd --type f --strip-cwd-prefix --hidden --follow --exclude .git"
export UV_PYTHON_INSTALL_MIRROR="https://gh-proxy.com/github.com/indygreg/python-build-standalone/releases/download/"
export UV_DEFAULT_INDEX="https://mirrors.aliyun.com/pypi/simple/"

# Source Ghostty shell integration manually for tmux
if [[ -n "$GHOSTTY_RESOURCES_DIR" ]] && [[ -r "$GHOSTTY_RESOURCES_DIR/shell-integration/zsh/ghostty-integration" ]]; then
  builtin source "$GHOSTTY_RESOURCES_DIR/shell-integration/zsh/ghostty-integration"
fi

# Ghostty shader
GHOSTTY_SHADER_HOME="${XDG_CONFIG_HOME:-${HOME}/.config}/ghostty/shaders"
[ ! -d "$GHOSTTY_SHADER_HOME" ] && mkdir -p "$(dirname "$GHOSTTY_SHADER_HOME")"
[ ! -d "$GHOSTTY_SHADER_HOME/.git" ] && git clone --depth=1 https://github.com/sahaj-b/ghostty-cursor-shaders "$GHOSTTY_SHADER_HOME"

# Tmux catppuccin theme
TMUX_CATPPUCCIN_HOME="${XDG_CONFIG_HOME:-${HOME}/.config}/tmux/plugins/catppuccin/tmux"
[ ! -d "$TMUX_CATPPUCCIN_HOME" ] && mkdir -p "$(dirname "$TMUX_CATPPUCCIN_HOME")"
[ ! -d "$TMUX_CATPPUCCIN_HOME/.git" ] && git clone --depth=1 https://github.com/catppuccin/tmux "$TMUX_CATPPUCCIN_HOME"

# Rclone directory
[ ! -d "$HOME/onedrive" ] && mkdir -p "$HOME/onedrive"

# Zinit
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit"
[ ! -d "$ZINIT_HOME" ] && mkdir -p "$(dirname $ZINIT_HOME)"
[ ! -d "$ZINIT_HOME/.git" ] && git clone --depth=1 https://github.com/zdharma-continuum/zinit "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"

# Plugins
zinit snippet OMZL::clipboard.zsh
zinit snippet OMZL::completion.zsh
zinit snippet OMZL::git.zsh
zinit snippet OMZL::history.zsh
zinit snippet OMZL::key-bindings.zsh
zinit snippet OMZL::theme-and-appearance.zsh
zinit snippet OMZP::git
zinit snippet OMZP::vi-mode
zinit snippet OMZP::last-working-dir
zinit wait lucid light-mode for \
  blockf atpull'zinit creinstall -q .' zsh-users/zsh-completions \
  atinit"zicompinit; zicdreplay" Aloxaf/fzf-tab \
  atload"_zsh_autosuggest_start" zsh-users/zsh-autosuggestions \
  atinit"_tool_init" zsh-users/zsh-syntax-highlighting

# Completion styling
zstyle ':completion:*:git-checkout:*' sort false
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always --icons --group-directories-first $realpath'
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'eza -1 --color=always --icons --group-directories-first $realpath'
zstyle ':fzf-tab:complete:nvim:*' fzf-preview \
  '[[ -d $realpath ]] && eza -1 --color=always --icons --group-directories-first "$realpath" | head -200 || \
  (bat --color=always --style=numbers "$realpath" || cat "$realpath") 2>/dev/null'
zstyle ':fzf-tab:*' use-fzf-default-opts yes
zstyle ':fzf-tab:*' prefix ''
zstyle ':fzf-tab:*' switch-group '<' '>'
# zstyle ':fzf-tab:*' fzf-command ftb-tmux-popup
# zstyle ':fzf-tab:*' popup-min-size 80 10

# Key bindings
bindkey "^O" autosuggest-accept

omz() {
  echo "==> Updating Zinit and plugins..."
  zinit self-update && zinit update --all --parallel
  echo "\n✓ All Zinit plugins updated!"
}

# Tool initialization
_tool_init() {
  (( $+commands[uv] )) && eval "$(uv generate-shell-completion zsh)"
  (( $+commands[uvx] )) && eval "$(uvx --generate-shell-completion zsh)"
  (( $+commands[mise] )) && eval "$(mise activate zsh)"
  (( $+commands[zoxide] )) && eval "$(zoxide init --cmd cd zsh)"
  (( $+commands[tv] )) && eval "$(tv init zsh)"
  (( $+commands[fzf] )) && source <(fzf --zsh)
  (( $+commands[fx] )) && source <(fx --comp zsh)
  (( $+commands[procs] )) && source <(procs --gen-completion-out zsh)
}

# Use fd for listing path candidates
_fzf_compgen_path() {
  fd --hidden --follow --exclude ".git" . "$1"
}

# Use fd for list directory candidates
_fzf_compgen_dir() {
  fd --type d --hidden --follow --exclude ".git" . "$1"
}

# Package helpers
alias yay="paru"
alias pac="paru -Slq | fzf --multi --preview 'paru -Si {1}' --preview-window=down:75% --layout=reverse | xargs -ro paru -S --needed"
alias pacr="paru -Qq | fzf --multi --preview 'paru -Qi {1}' --preview-window=down:75% --layout=reverse | xargs -ro paru -Rns"
alias pacl="paru -Qq | fzf --preview 'paru -Qil {1}' --preview-window=down:75% --layout=reverse --bind 'enter:execute(paru -Qil {} | bat --color=always --paging=always)'"
alias pacu="paru -Qu | awk '{print \$1}' | paru -Si - | cat"

# CLI aliases
alias dot="chezmoi"
alias open="xdg-open"
alias ff="fastfetch --config examples/7.jsonc"
alias cat="bat"
alias ls="eza --icons --grid --group-directories-first"
alias find="fd --hidden --follow --exclude .git"
alias grep="rg"
alias help="tldr"
alias du="dust"
alias df="duf"
alias top="btm"
alias ps="procs"
alias ping="gping"
alias curl="curlie"
alias dig="doggo"
alias diff="delta"
alias vi="nvim"
alias vim="nvim"
alias svim="sudoedit"

# Coding agents
alias cc="claude"
alias ccc="claude -c"
alias ccr="claude -r"
alias ccm="claude -p commit"
alias cx="codex"
alias cxr="codex resume"
alias oc="opencode"
alias occ="opencode -c"

# GitHub workflow
alias gpn="gh pr new"
alias gpc="gh pr checks --watch"
alias gpm="gh pr merge --squash --delete-branch"

# Misc
alias onedrive="rclone mount onedrive:/ ~/onedrive --vfs-cache-mode full --daemon"
alias ncm="/opt/SPlayer/SPlayer"

[ ! -f "$HOME/.zshrc.local" ] && touch ~/.zshrc.local
source ~/.zshrc.local

eval "$(starship init zsh)"

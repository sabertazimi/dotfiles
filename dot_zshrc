# Environment
export EDITOR="nvim"
export VISUAL="nvim"
export MANPAGER="bat -l man -p"
export PNPM_HOME="$HOME/.local/share/pnpm"
export PATH="$HOME/.local/bin:$PNPM_HOME/bin:$HOME/.cargo/bin:$HOME/go/bin:$PATH"
export FZF_DEFAULT_COMMAND="fd --type f --strip-cwd-prefix --hidden --follow --exclude .git"
export FZF_CTRL_T_COMMAND="fd --strip-cwd-prefix --hidden --follow --exclude .git"
export FZF_DEFAULT_OPTS="--bind 'ctrl-d:preview-half-page-down,ctrl-u:preview-half-page-up,ctrl-/:change-preview-window(down|hidden|)'"
export FZF_CTRL_T_OPTS="
  --preview 'fzf-preview.sh {}'
  --bind 'ctrl-y:execute-silent(echo -n {} | wl-copy)+abort'
  --color header:italic
  --header 'Press CTRL-Y to copy path'"
export FZF_CTRL_R_OPTS="
  --bind 'ctrl-y:execute-silent(echo -n {2..} | wl-copy)+abort'
  --color header:italic
  --header 'Press CTRL-Y to copy command'"
export RIPGREP_CONFIG_PATH="$HOME/.ripgreprc"
export UV_PYTHON_INSTALL_MIRROR="https://gh-proxy.com/github.com/indygreg/python-build-standalone/releases/download/"
export UV_DEFAULT_INDEX="https://pypi.tuna.tsinghua.edu.cn/simple/"
export PYTHON_AUTO_VRUN=true
export VIRTUAL_ENV_DISABLE_PROMPT=true

# Enable the subsequent settings only in interactive sessions
case $- in
  *i*) ;;
    *) return;;
esac

# Source Ghostty shell integration manually for tmux
if [[ -n "$GHOSTTY_RESOURCES_DIR" ]] && [[ -r "$GHOSTTY_RESOURCES_DIR/shell-integration/zsh/ghostty-integration" ]]; then
  builtin source "$GHOSTTY_RESOURCES_DIR/shell-integration/zsh/ghostty-integration"
fi

# Plugins from GitHub
github_plugins=(
  "${XDG_CONFIG_HOME:-$HOME/.config}/ghostty/shaders https://github.com/sahaj-b/ghostty-cursor-shaders"
  "${XDG_CONFIG_HOME:-$HOME/.config}/tmux/plugins/catppuccin/tmux https://github.com/catppuccin/tmux"
)
for entry in "${github_plugins[@]}"; do
  local dest="${entry%% *}" url="${entry#* }"
  [ ! -d "$dest" ] && mkdir -p "$(dirname "$dest")"
  [ ! -d "$dest/.git" ] && echo "Installing $(basename "$(dirname "$dest")")/$(basename "$dest")..." && git clone --depth=1 --quiet "$url" "$dest"
done

# Rclone directory
[ ! -d "$HOME/onedrive" ] && mkdir -p "$HOME/onedrive"

# Zinit
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit"
[ ! -d "$ZINIT_HOME" ] && mkdir -p "$(dirname $ZINIT_HOME)"
[ ! -d "$ZINIT_HOME/.git" ] && echo "Installing zinit..." && git clone --depth=1 --quiet https://github.com/zdharma-continuum/zinit "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"

# Plugins
zinit snippet OMZL::clipboard.zsh
zinit snippet OMZL::completion.zsh
zinit snippet OMZL::git.zsh
zinit snippet OMZL::history.zsh
zinit snippet OMZL::key-bindings.zsh
zinit snippet OMZL::theme-and-appearance.zsh
zinit snippet OMZP::git
zinit snippet OMZP::python
zinit snippet OMZP::vi-mode
zinit snippet OMZP::last-working-dir
zinit wait lucid light-mode for \
  blockf atpull'zinit creinstall -q .' zsh-users/zsh-completions \
  atclone"./zplug.zsh" atpull"%atclone" g-plane/pnpm-shell-completion \
  atinit"zicompinit; zicdreplay" Aloxaf/fzf-tab \
  atload"_zsh_autosuggest_start" zsh-users/zsh-autosuggestions \
  atinit"_tool_init" zsh-users/zsh-syntax-highlighting

omz() {
  echo "==> Updating Zinit and plugins..."
  zinit self-update && zinit update --all --parallel
  for entry in "${github_plugins[@]}"; do
    local dest="${entry%% *}"
    echo "==> Updating $(basename "$(dirname "$dest")")/$(basename "$dest")..."
    git -C "$dest" pull --quiet
  done
  echo "\n✓ All plugins updated!"
}

# Tool initialization
_tool_init() {
  (( $+commands[uv] )) && eval "$(uv generate-shell-completion zsh)"
  (( $+commands[uvx] )) && eval "$(uvx --generate-shell-completion zsh)"
  (( $+commands[zoxide] )) && eval "$(zoxide init --cmd cd zsh)"
  (( $+commands[tv] )) && eval "$(tv init zsh)"
  (( $+commands[fzf] )) && source <(fzf --zsh)
  (( $+commands[fx] )) && source <(fx --comp zsh)
  (( $+commands[procs] )) && source <(procs --gen-completion-out zsh)
  compdef curlie=curl
  compdef pacman-owns.sh=which
}

# Use fd for listing path candidates
_fzf_compgen_path() {
  fd --hidden --follow --exclude ".git" . "$1"
}

# Use fd for list directory candidates
_fzf_compgen_dir() {
  fd --type d --hidden --follow --exclude ".git" . "$1"
}

# Completion styling
zstyle ':completion:*:git-checkout:*' sort false
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:(cd|__zoxide_z|mv|vim|nvim):*' fzf-preview 'fzf-preview.sh $realpath'
zstyle ':fzf-tab:*' use-fzf-default-opts yes
zstyle ':fzf-tab:*' prefix ''
zstyle ':fzf-tab:*' switch-group '<' '>'

# Key bindings
bindkey " " magic-space
bindkey "^O" autosuggest-accept
bindkey "^G" edit-command-line
bindkey "^X^E" edit-command-line

# Package helpers
alias yay="paru"
alias pac="tv aur"
alias pacl="tv pacman-packages"
alias pacu="paru -Quq | fzf --multi --preview 'paru -Qi {1}' --preview-window=down:75% --layout=reverse | xargs -ro paru -Su --needed"
alias paco="pacman-owns.sh"

# CLI aliases
alias cl="clear"
alias help="tldr"
alias cat="bat"
alias ls="eza --icons --group-directories-first"
alias l="ls"
alias ll="ls -lh --git"
alias la="ls -alh --git"
alias tree="ls --tree"
alias find="fd --hidden --follow --exclude .git"
alias grep="rg"
alias ps="procs"
alias df="duf"
alias du="dust"
alias top="btm"
alias ff="fastfetch --config examples/7.jsonc"
alias ping="gping"
alias curl="curlie"
alias dig="doggo"
alias diff="delta"
alias vi="nvim"
alias vim="nvim"
alias dvim="chezmoi edit"
alias svim="sudoedit"
alias open="xdg-open"
alias dot="chezmoi"
alias -g NE="2> /dev/null"
alias -g NO=">/dev/null"
alias -g NUL="> /dev/null 2>&1"

# Coding agents
alias cc="claude"
alias ccc="claude -c"
alias ccr="claude -r"
alias ccm="claude -p commit"

# Git workflow
alias lg="lazygit"
alias gan="git add -N"
alias gpot="git push origin --follow-tags"
alias gtd="git tag --delete"

# GitHub workflow
alias gpn="gh pr new"
alias gpc="gh pr checks --watch"
alias gpm="gh pr merge --squash --delete-branch"

# Misc
alias onedrive="rclone mount onedrive:/ ~/onedrive --vfs-cache-mode full --daemon"
alias ncm="tmux-music.sh"

[ ! -f "$HOME/.zshrc.local" ] && touch ~/.zshrc.local
source ~/.zshrc.local

eval "$(starship init zsh)"

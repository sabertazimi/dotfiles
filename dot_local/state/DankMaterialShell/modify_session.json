#!/usr/bin/env bash

USER=$(whoami)
jq -j --arg user "$USER" '
  .wallpaperCyclingEnabled = true |
  .wallpaperCyclingMode = "interval" |
  .wallpaperCyclingInterval = 1800 |
  .wallpaperCyclingTime = "18:00" |
  .wallpaperTransition = "disc" |
  .hiddenApps = [
  "wps-office-wps",
  "wps-office-et",
  "wps-office-wpp",
  "wps-office-pdf"
]
'

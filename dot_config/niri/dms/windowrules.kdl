// DMS Window Rules - Managed by DankMaterialShell
// Do not edit manually - changes may be overwritten

window-rule {
    opacity 0.85
    background-effect {
        blur true
    }
}

window-rule {
    match app-id="^firefox$"
    match app-id="^google-chrome"
    match app-id="^imv$"
    match app-id="^mpv$"
    match app-id="^steam_app_[0-9]+$"

    opacity 1.0
    open-maximized true
}

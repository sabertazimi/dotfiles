#!/usr/bin/env bash

# Idempotent niri config.kdl modifier
# Usage: cat ~/.config/niri/config.kdl | ./modify_config.kdl > ~/.config/niri/config.kdl.new

# Read entire content from stdin
content=$(cat)

# Helper function to check if a line exists in content
# Supports literal string match or /regexp/
line_exists() {
  local pattern="$1"
  if [[ "$pattern" == /*/ ]]; then
    pattern="${pattern:1:-1}"
    echo "$content" | grep -qE -- "$pattern"
  else
    echo "$content" | grep -qF -- "$pattern"
  fi
}

# 1. Add layout always-center-single-column
if ! line_exists 'always-center-single-column'; then
  content=$(awk '
        /^[[:space:]]*layout[[:space:]]*{/ && !center_added {
            print
            print "    always-center-single-column"
            center_added = 1
            next
        }
        { print }
    ' <<<"$content")
fi

# 2. Add QT environment variables
if ! line_exists 'QT_QPA_PLATFORMTHEME "qt6ct"'; then
  content=$(awk '
        /^[[:space:]]*environment[[:space:]]*{/ && !qt_added {
            print
            print "  QT_QPA_PLATFORMTHEME \"qt6ct\""
            print "  QT_QPA_PLATFORMTHEME_QT6 \"qt6ct\""
            qt_added = 1
            next
        }
        { print }
    ' <<<"$content")
fi

# 3. Add locale environment variables
if ! line_exists 'LC_CTYPE "en_US.UTF-8"'; then
  content=$(awk '
        /^[[:space:]]*environment[[:space:]]*{/ && !locale_added {
            print
            print "  LC_CTYPE \"en_US.UTF-8\""
            print "  XMODIFIERS \"@im=fcitx\""
            print "  LANG \"zh_CN.UTF-8\""
            locale_added = 1
            next
        }
        { print }
    ' <<<"$content")
fi

# 4. Replace scope="output" with scope="all"
content="${content//scope=\"output\"/scope=\"all\"}"

# 5. Add optional `windowrules` include
if ! line_exists 'include "dms/windowrules.kdl"'; then
  windowrules_file="${XDG_CONFIG_HOME:-$HOME/.config}/niri/dms/windowrules.kdl"
  if [ -f "$windowrules_file" ]; then
    content="${content}"$'\n'"include \"dms/windowrules.kdl\""
  fi
fi

# 6. Add fcitx5 spawn-at-startup
if ! line_exists 'spawn-at-startup "fcitx5" "-d"'; then
  content="${content}"$'\n'"spawn-at-startup \"fcitx5\" \"-d\""
fi

# 7. Add rclone onedrive mount spawn-at-startup
if ! line_exists '/spawn.*rclone/'; then
  content="${content}"$'\n'"spawn-sh-at-startup \"mkdir -p ~/Documents/onedrive && rclone mount onedrive:/ ~/Documents/onedrive --vfs-cache-mode full --daemon\""
fi

# Output modified content
echo "$content"

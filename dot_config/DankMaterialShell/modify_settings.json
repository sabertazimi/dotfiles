#!/usr/bin/env bash

jq -j '
  .wallpaperFillMode = "Fill" |
  .currentThemeName = "dynamic" |
  .currentThemeCategory = "dynamic" |
  .matugenScheme = "scheme-tonal-spot" |
  .matugenTemplateNeovim = false |
  .matugenTemplateVscode = false |
  .iconTheme = "Papirus" |
  .fontFamily = "思源黑体 CN" |
  .monoFontFamily = "Maple Mono NF CN" |
  .use24HourClock = true |
  .weatherEnabled = true |
  .barConfigs |= map(
    if .id == "default" or .id == null then
      .transparency = 0.85 | .widgetTransparency = 0
    else . end
  ) |
  .showOccupiedWorkspacesOnly = true |
  .notificationRules = [
  {
    "enabled": true,
    "field": "appName",
    "pattern": "Firefox",
    "matchType": "exact",
    "action": "mute",
    "urgency": "default"
  }
] |
  .showDock = true |
  .dockSmartAutoHide = true |
  .dockGroupByApp = true |
  .dockTransparency = 0.85 |
  .launcherLogoMode = "os" |
  .launcherLogoColorOverride = "primary"
'
